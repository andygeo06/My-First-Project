# --- 2. THE SIGNAL FUNCTION (Bridges Cloud to your Local Server) ---
def send_signal_to_local_server(user_name, user_email, dtrak_list):
    """Sends a signal email to the bot to trigger the local office server."""
    bot_email = st.secrets["BOT_EMAIL"]
    bot_password = st.secrets["BOT_PASSWORD"] # Use App Password
    
    # We combine the DTRAKs into one message for your local app to process
    for dtrak in dtrak_list:
        msg = MIMEText(f"Auto-Request for: {dtrak}")
        msg['Subject'] = dtrak
        msg['From'] = "Sentinel Cloud"
        msg['To'] = bot_email
        msg['Reply-To'] = user_email # This is how your local app knows where to send the file
        
        try:
            with smtplib.SMTP_SSL('smtp.gmail.com', 465) as server:
                server.login(bot_email, bot_password)
                server.send_message(msg)
        except Exception as e:
            st.error(f"Signal Failed: {e}")
            return False
    return True

# --- 3. DATA CONNECTION ---
# In the cloud, this URL comes from st.secrets
URL = st.secrets["gsheets_url"]
conn = st.connection("gsheets", type=GSheetsConnection)

try:
    # Pulling from your INCOMING SEARCH tab
    df = conn.read(spreadsheet=URL, worksheet="INCOMING SEARCH", ttl="10m")
except:
    st.error("Connection to Google Sheets failed. Check your Secrets.")
    st.stop()

# --- 4. THE LAYOUT (3:1) ---
col_main, col_action = st.columns([3, 1], gap="large")

with col_main:
    st.title("🛡️ Sentinel Cloud Portal")
    st.caption("20th Congress Document Tracking System")
    
    query = st.text_input("", placeholder="🔍 Search by Subject, DTRAK, or Office...")

    # Filter Logic
    if query:
        mask = df.astype(str).apply(lambda x: x.str.contains(query, case=False)).any(axis=1)
        filtered_df = df[mask]
    else:
        filtered_df = df

    # The Grid
    selection = st.dataframe(
        filtered_df, 
        use_container_width=True, 
        hide_index=True,
        on_select="rerun",
        selection_mode="multi-row"
    )

with col_action:
